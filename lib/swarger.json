    "components": {
      "schemas": {
        "SizeDto": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "ReviewDto": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "productId": {
              "type": "string"
            },
            "rating": {
              "type": "integer",
              "format": "int32",
              "maximum": 5,
              "minimum": 1
            },
            "comment": {
              "type": "string",
              "maxLength": 500,
              "minLength": 0
            }
          },
          "required": [
            "comment",
            "productId",
            "rating"
          ]
        },
        "PromotionDto": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "productId": {
              "type": "string"
            },
            "discountedPrice": {
              "type": "number"
            },
            "startDate": {
              "type": "string",
              "format": "date"
            },
            "endDate": {
              "type": "string",
              "format": "date"
            }
          },
          "required": [
            "discountedPrice",
            "endDate",
            "productId",
            "startDate"
          ]
        },
        "Category": {
          "type": "object",
          "properties": {
